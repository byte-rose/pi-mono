{
  "name": "@byte-rose/nyati-security-tools",
  "version": "0.1.0",
  "description": "Typed tool definitions for nyati security agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
