{
  "name": "@byte-rose/nyati-security-reporting",
  "version": "0.1.0",
  "description": "CVSS helpers, dedupe logic, and report exporters for nyati security agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
