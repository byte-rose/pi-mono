{
  "name": "@byte-rose/nyati-security-artifacts",
  "version": "0.1.0",
  "description": "Structured artifact models and persistence for nyati security agent",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "node --test dist/**/*.test.js 2>/dev/null || true"
  },
  "dependencies": {
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.2"
  }
}
